<Window x:Class="IDO_GEN_WordManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:IDO_GEN_WordManager.ViewModels"
        xmlns:models="clr-namespace:IDO_GEN_WordManager.Models"
        Title="IDO GEN — Word Manager"
        Height="680" Width="1000"
        MinWidth="750" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════ HEADER ═══════════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <Grid Margin="24,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📄" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="IDO GEN — Word Manager"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="Gestión de estructura de documentos Word"
                                   Foreground="#A0BDD8" FontSize="11"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════ TOOLBAR ═══════════════════════ -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <!-- Opción exportar -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="📂  Cargar Word"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadFileCommand}"
                        ToolTip="Seleccionar un archivo .docx"/>

                <Button Grid.Column="2" Content="✔ Seleccionar todo"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding SelectAllCommand}"/>

                <Button Grid.Column="4" Content="✖ Deseleccionar todo"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding DeselectAllCommand}"/>

                <!-- Toggle sobreescribir / copia -->
                <Border Grid.Column="6"
                        Background="#F7FAFC" BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="10,6">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox IsChecked="{Binding OverwriteSource, Mode=TwoWay}"
                                  VerticalAlignment="Center" Margin="0,0,8,0" Cursor="Hand"/>
                        <TextBlock Text="{Binding ExportModeLabel}"
                                   FontSize="12" Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="8" Content="💾  Exportar Word"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding ExportCommand}"
                        ToolTip="Exportar documento eliminando los encabezados ocultos"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════ FILE INFO ═══════════════════════ -->
        <Border Grid.Row="2" Background="#EBF5FF"
                BorderBrush="#BEE3F8" BorderThickness="0,0,0,1"
                Padding="20,8"
                Visibility="{Binding IsFileLoaded, Converter={StaticResource BoolToVisConverter}}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Archivo: " FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12"/>
                <TextBlock Text="{Binding FileName}"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12" Margin="0,0,16,0"/>
                <TextBlock Text="|" Foreground="{StaticResource BorderBrush}" Margin="0,0,16,0"/>
                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text=" encabezados encontrados"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════ DATAGRID ═══════════════════════ -->
        <Border Grid.Row="3" Margin="16,12,16,0"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8"
                ClipToBounds="True">
            <DataGrid x:Name="HeadingsGrid"
                      ItemsSource="{Binding Headings}"
                      BorderThickness="0">

                <DataGrid.Columns>

                    <!-- Expand/Collapse -->
                    <DataGridTemplateColumn Header="" Width="32" CanUserSort="False" CanUserResize="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DocumentHeading}">
                                <Button Content="{Binding ExpandIcon}"
                                        FontSize="9" Width="20" Height="20"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Command="{Binding DataContext.ToggleExpandCommand,
                                                  RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Visibility="{Binding HasChildren, Converter={StaticResource BoolToVisConverter}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Visible checkbox -->
                    <DataGridTemplateColumn Header="Acción" Width="160" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DocumentHeading}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- Botón Ocultar -->
                                    <ToggleButton IsChecked="{Binding IsHide, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="68" Height="26" Cursor="Hand" Margin="0,0,4,0"
                                                  ToolTip="Ocultar encabezado en la exportación">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="Bd" CornerRadius="5" BorderThickness="1"
                                                                    BorderBrush="#CBD5E0" Background="#EDF2F7"
                                                                    Padding="6,2">
                                                                <TextBlock x:Name="Txt" Text="👁 Ocultar"
                                                                           FontSize="11" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#FFF3CD"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#F6AD55"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="#C05621"/>
                                                                    <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#FEF9EC"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <!-- Botón Eliminar -->
                                    <ToggleButton IsChecked="{Binding IsDelete, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Width="72" Height="26" Cursor="Hand"
                                                  ToolTip="Eliminar encabezado en la exportación">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="Bd" CornerRadius="5" BorderThickness="1"
                                                                    BorderBrush="#CBD5E0" Background="#EDF2F7"
                                                                    Padding="6,2">
                                                                <TextBlock x:Name="Txt" Text="🗑 Eliminar"
                                                                           FontSize="11" HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#FED7D7"/>
                                                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#FC8181"/>
                                                                    <Setter TargetName="Txt" Property="Foreground" Value="#C53030"/>
                                                                    <Setter TargetName="Txt" Property="FontWeight" Value="SemiBold"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="#FFF5F5"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Nivel badge -->
                    <DataGridTemplateColumn Header="Nivel" Width="90" CanUserSort="True" SortMemberPath="Level">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DocumentHeading}">
                                <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="6,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="1">
                                                    <Setter Property="Background" Value="{StaticResource Level1BadgeBg}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="2">
                                                    <Setter Property="Background" Value="{StaticResource Level2BadgeBg}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="3">
                                                    <Setter Property="Background" Value="{StaticResource Level3BadgeBg}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding LevelLabel}" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="1">
                                                        <Setter Property="Foreground" Value="{StaticResource Level1Brush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="2">
                                                        <Setter Property="Foreground" Value="{StaticResource Level2Brush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="3">
                                                        <Setter Property="Foreground" Value="{StaticResource Level3Brush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Número jerárquico -->
                    <DataGridTemplateColumn Header="N°" Width="80" CanUserSort="True" SortMemberPath="NumberLabel">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DocumentHeading}">
                                <TextBlock Text="{Binding NumberLabel}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"
                                           FontSize="12" FontFamily="Consolas" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="1">
                                                    <Setter Property="Foreground" Value="{StaticResource Level1Brush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="2">
                                                    <Setter Property="Foreground" Value="{StaticResource Level2Brush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="3">
                                                    <Setter Property="Foreground" Value="{StaticResource Level3Brush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Texto con indentación visual -->
                    <DataGridTemplateColumn Header="Texto del encabezado" Width="*" CanUserSort="True" SortMemberPath="Text">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate DataType="{x:Type models:DocumentHeading}">
                                <TextBlock Text="{Binding Text}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Text}"
                                           Opacity="{Binding RowOpacity}"
                                           Margin="{Binding LevelIndent, Converter={StaticResource IndentToMarginConverter}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="1">
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                    <Setter Property="FontSize" Value="14"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Level1Brush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="2">
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="FontSize" Value="13"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Level2Brush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="3">
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                    <Setter Property="FontSize" Value="12"/>
                                                    <Setter Property="Foreground" Value="{StaticResource Level3Brush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TextDecoration}" Value="Strikethrough">
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

                <!-- Color de fila: amarillo claro=ocultar, rojo claro=eliminar -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Background" Value="{Binding RowBackground}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#BBDEFB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Style>
                    <Style TargetType="DataGrid" BasedOn="{StaticResource CleanDataGrid}">
                        <Style.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGrid">
                                            <Border Background="White">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5">
                                                    <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                                    <TextBlock Text="Carga un archivo Word para comenzar"
                                                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Se mostrarán aquí los títulos, subtítulos y capítulos"
                                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>

            </DataGrid>
        </Border>

        <!-- ═══════════════════════ STATUS BAR ═══════════════════════ -->
        <Border Grid.Row="4" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Margin="0,12,0,0" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding StatusMessage}"
                           VerticalAlignment="Center" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                        <Run Text="Visibles: "/>
                        <Run Text="{Binding VisibleCount, Mode=OneWay}"
                             Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
