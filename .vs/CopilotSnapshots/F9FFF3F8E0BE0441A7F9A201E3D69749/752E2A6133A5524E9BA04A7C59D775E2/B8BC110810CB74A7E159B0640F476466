using IDO_GEN_WordManager.Models;
using System;
using System.Collections.Generic;
using System.IO;
using System.Runtime.InteropServices;
using Word = Microsoft.Office.Interop.Word;

namespace IDO_GEN_WordManager.Services
{
    public class WordReaderService
    {
        public List<DocumentHeading> LoadHeadings(string filePath)
        {
            var result = new List<DocumentHeading>();
            if (!File.Exists(filePath))
            {
                return result;
            }

            Word.Application? wordApp = null;
            Word.Document? wordDoc = null;

            try
            {
                wordApp = new Word.Application
                {
                    Visible = false,
                    DisplayAlerts = Word.WdAlertLevel.wdAlertsNone
                };

                wordDoc = wordApp.Documents.Open(
                    FileName: Path.GetFullPath(filePath),
                    ReadOnly: true,
                    AddToRecentFiles: false,
                    Visible: false);

                var paragraphIndex = 0;
                foreach (Word.Paragraph paragraph in wordDoc.Paragraphs)
                {
                    try
                    {
                        var style = paragraph.get_Style() as Word.Style;
                        if (style == null)
                        {
                            paragraphIndex++;
                            continue;
                        }

                        var level = GetHeadingLevel(style);
                        if (level < 1 || level > 3)
                        {
                            paragraphIndex++;
                            continue;
                        }

                        var text = paragraph.Range.Text?
                            .Replace("\r", string.Empty)
                            .Replace("\n", string.Empty)
                            .Replace("\a", string.Empty)
                            .Trim();
                        if (string.IsNullOrWhiteSpace(text))
                        {
                            paragraphIndex++;
                            continue;
                        }

                        string wordNumber;
                        try
                        {
                            wordNumber = paragraph.Range.ListFormat.ListString ?? string.Empty;
                        }
                        catch
                        {
                            wordNumber = string.Empty;
                        }

                        result.Add(new DocumentHeading
                        {
                            ParagraphIndex = paragraphIndex,
                            Level = level,
                            Text = text,
                            WordNumber = wordNumber.Trim()
                        });
                    }
                    finally
                    {
                        Marshal.ReleaseComObject(paragraph);
                        paragraphIndex++;
                    }
                }

                MarkHasChildren(result);
                return result;
            }
            finally
            {
                if (wordDoc != null)
                {
                    wordDoc.Close(Word.WdSaveOptions.wdDoNotSaveChanges);
                    Marshal.ReleaseComObject(wordDoc);
                }

                if (wordApp != null)
                {
                    wordApp.Quit(Word.WdSaveOptions.wdDoNotSaveChanges);
                    Marshal.ReleaseComObject(wordApp);
                }
            }
        }

        private static int GetHeadingLevel(Word.Style style)
        {
            try
            {
                var outlineLevel = (int)style.ParagraphFormat.OutlineLevel;
                if (outlineLevel >= 1 && outlineLevel <= 3)
                {
                    return outlineLevel;
                }

                var styleName = (style.NameLocal ?? string.Empty)
                    .Replace(" ", string.Empty)
                    .ToLowerInvariant();

                foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
                {
                    if (!styleName.StartsWith(prefix))
                    {
                        continue;
                    }

                    var suffix = styleName.Substring(prefix.Length);
                    if (suffix == "1") return 1;
                    if (suffix == "2") return 2;
                    if (suffix == "3") return 3;
                }
            }
            catch
            {
            }

            return 0;
        }

        private static void MarkHasChildren(List<DocumentHeading> headings)
        {
            for (var i = 0; i < headings.Count - 1; i++)
            {
                headings[i].HasChildren = headings[i + 1].Level > headings[i].Level;
            }
        }
    }
}
