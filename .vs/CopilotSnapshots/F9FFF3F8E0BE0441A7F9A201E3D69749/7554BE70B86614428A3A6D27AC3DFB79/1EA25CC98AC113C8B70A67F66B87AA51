        public List<DocumentHeading> LoadHeadings(string filePath)
        {
            var result = new List<DocumentHeading>();
            if (!File.Exists(filePath)) return result;

            Word.Application? wordApp = null;
            Word.Document? wordDoc = null;

            try
            {
                wordApp = new Word.Application { Visible = false, DisplayAlerts = Word.WdAlertLevel.wdAlertsNone };
                wordDoc = wordApp.Documents.Open(
                    FileName: Path.GetFullPath(filePath),
                    ReadOnly: true,
                    AddToRecentFiles: false);

                foreach (Word.Paragraph para in wordDoc.Paragraphs)
                {
                    var style = para.Style as Word.Style;
                    if (style == null) continue;

                    int level = GetHeadingLevel(style);
                    if (level < 1 || level > 3) continue;

                    var text = para.Range.Text?.Trim('\r', '\n', '\a')?.Trim();
                    if (string.IsNullOrWhiteSpace(text)) continue;

                    // ListFormat.ListString es el número EXACTO que Word muestra
                    var wordNumber = string.Empty;
                    try { wordNumber = para.Range.ListFormat.ListString ?? string.Empty; }
                    catch { /* algunos párrafos no tienen lista */ }

                    // El índice del párrafo en la colección de Word (1-based)
                    int paraIndex = para.Range.Paragraphs[1].Range.Start;

                    result.Add(new DocumentHeading
                    {
                        ParagraphIndex = paraIndex,
                        Level = level,
                        Text = text,
                        WordNumber = wordNumber.Trim()
                    });
                }

                MarkHasChildren(result);
            }
            finally
            {
                if (wordDoc != null)
                {
                    wordDoc.Close(Word.WdSaveOptions.wdDoNotSaveChanges);
                    Marshal.ReleaseComObject(wordDoc);
                }
                if (wordApp != null)
                {
                    wordApp.Quit(Word.WdSaveOptions.wdDoNotSaveChanges);
                    Marshal.ReleaseComObject(wordApp);
                }
            }

            return result;
        }

        private static int GetHeadingLevel(Word.Style style)
        {
            try
            {
                // WdBuiltinStyle: wdStyleHeading1 = -2, wdStyleHeading2 = -3, wdStyleHeading3 = -4
                var builtIn = style.BuiltIn;
                if (builtIn)
                {
                    var nameId = style.NameLocal?.ToLowerInvariant() ?? string.Empty;
                    // OutlineLevel es la forma más confiable
                    var ol = (int)style.ParagraphFormat.OutlineLevel;
                    if (ol >= 1 && ol <= 3) return ol;
                }

                // Fallback: nombre del estilo
                var name = (style.NameLocal ?? string.Empty).Replace(" ", "").ToLowerInvariant();
                foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
                {
                    if (!name.StartsWith(prefix)) continue;
                    var rest = name.Substring(prefix.Length);
                    if (rest == "1") return 1;
                    if (rest == "2") return 2;
                    if (rest == "3") return 3;
                }
            }
            catch { }

            return 0;
        }

        private static void MarkHasChildren(List<DocumentHeading> headings)
        {
            for (int i = 0; i < headings.Count - 1; i++)
                headings[i].HasChildren = headings[i + 1].Level > headings[i].Level;
