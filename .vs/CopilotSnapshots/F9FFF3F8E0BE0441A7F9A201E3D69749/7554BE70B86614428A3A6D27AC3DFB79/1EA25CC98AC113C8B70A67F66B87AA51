        /// <summary>
        /// Recorre TODOS los párrafos (no solo headings) y computa el número de numeración
        /// visible para cada párrafo que participa en una lista.
        /// </summary>
        private static Dictionary<int, string> ComputeAllNumbers(
            List<Paragraph> paragraphs,
            NumberingDefinitionsPart? numPart,
            Dictionary<string, (int numId, int ilvl)> styleNumIds)
        {
            var result = new Dictionary<int, string>();

            if (numPart?.Numbering == null)
            {
                // Sin numbering part: generar números jerárquicos por nivel de heading
                return result;
            }

            // numId -> abstractNumId
            var numToAbstract = new Dictionary<int, int>();
            // numId -> startOverrides (ilvl -> start) — solo los que aún no se aplicaron
            var startOverrides = new Dictionary<int, Dictionary<int, int>>();
            // abstractNumId -> formato de número por nivel (para saber cuántos niveles mostrar)
            var abstractFormats = new Dictionary<int, Dictionary<int, string>>();

            foreach (var num in numPart.Numbering.Elements<NumberingInstance>())
            {
                var nid = num.NumberID?.Value ?? 0;
                var aid = num.AbstractNumId?.Val?.Value ?? 0;
                numToAbstract[nid] = aid;

                var ov = new Dictionary<int, int>();
                foreach (var lo in num.Elements<LevelOverride>())
                {
                    var lvl = lo.LevelIndex?.Value ?? 0;
                    var sv = lo.StartOverrideNumberingValue?.Val?.Value;
                    if (sv.HasValue) ov[lvl] = sv.Value;
                }
                if (ov.Count > 0) startOverrides[nid] = ov;
            }

            foreach (var abs in numPart.Numbering.Elements<AbstractNum>())
            {
                var aid = abs.AbstractNumberId?.Value ?? 0;
                var formats = new Dictionary<int, string>();
                foreach (var lvl in abs.Elements<Level>())
                {
                    var ilvl = lvl.LevelIndex?.Value ?? 0;
                    var fmt = lvl.LevelText?.Val?.Value ?? string.Empty;
                    formats[ilvl] = fmt;
                }
                abstractFormats[aid] = formats;
            }

            // Contadores: abstractNumId -> int[9] (contadores por nivel)
            var counters = new Dictionary<int, int[]>();
            foreach (var aid in numToAbstract.Values.Distinct())
                counters[aid] = new int[9];

            for (int idx = 0; idx < paragraphs.Count; idx++)
            {
                var para = paragraphs[idx];
                var ppr = para.ParagraphProperties;
                var numPr = ppr?.NumberingProperties;

                int numId = numPr?.NumberingId?.Val?.Value ?? 0;
                int ilvl = numPr?.NumberingLevelReference?.Val?.Value ?? -1;

                // Si no tiene numPr directo, intentar por estilo
                if (numId == 0)
                {
                    var sid = ppr?.ParagraphStyleId?.Val?.Value;
                    if (sid != null && styleNumIds.TryGetValue(sid, out var sn))
                    {
                        numId = sn.numId;
                        if (ilvl < 0) ilvl = sn.ilvl;
                    }
                }

                if (numId == 0 || !numToAbstract.TryGetValue(numId, out int absId))
                    continue;

                if (ilvl < 0) ilvl = 0;
                if (!counters.TryGetValue(absId, out var ctr))
                {
                    ctr = new int[9];
                    counters[absId] = ctr;
                }

                // Aplicar startOverride
                if (startOverrides.TryGetValue(numId, out var ovMap) && ovMap.TryGetValue(ilvl, out int startVal))
                {
                    ctr[ilvl] = startVal - 1;
                    ovMap.Remove(ilvl);
                }

                // Incrementar nivel actual
                ctr[ilvl]++;

                // Resetear niveles inferiores
                for (int i = ilvl + 1; i < ctr.Length; i++)
                    ctr[i] = 0;

                // Formatear el número usando el LevelText del abstractNum
                string formatted;
                if (abstractFormats.TryGetValue(absId, out var fmts) && fmts.TryGetValue(ilvl, out string? lvlText))
                {
                    formatted = FormatLevelText(lvlText, ctr);
                }
                else
                {
                    // Fallback: mostrar solo el contador del nivel actual
                    var parts = new List<string>();
                    for (int i = 0; i <= ilvl; i++)
                        if (ctr[i] > 0) parts.Add(ctr[i].ToString());
                    formatted = string.Join(".", parts);
                }

                result[idx] = formatted;
            }

            return result;
        }

        /// <summary>
        /// Formatea el LevelText de Word. Ej: "%1.%2.%3" reemplaza %N con el contador del nivel N-1.
        /// </summary>
        private static string FormatLevelText(string levelText, int[] counters)
        {
            // Word usa %1, %2, %3 como placeholders para nivel 0, 1, 2 respectivamente
            var formatted = Regex.Replace(levelText, @"%(\d)", m =>
            {
                int lvl = int.Parse(m.Groups[1].Value) - 1; // %1 = nivel 0
                return lvl >= 0 && lvl < counters.Length ? counters[lvl].ToString() : "0";
            });

            // Limpiar trailing dots/chars si algún nivel es 0
            formatted = formatted.TrimEnd('.');
            return formatted;
        }

        /// <summary>
        /// Lee los numId implícitos definidos en los estilos (ej: Heading1 suele tener un numId asociado).
        /// </summary>
        private static Dictionary<string, (int numId, int ilvl)> ResolveStyleNumbering(
            StyleDefinitionsPart? stylePart, NumberingDefinitionsPart? numPart)
        {
            var map = new Dictionary<string, (int, int)>(StringComparer.OrdinalIgnoreCase);
            if (stylePart?.Styles == null) return map;

            foreach (var style in stylePart.Styles.Elements<Style>())
            {
                var sid = style.StyleId?.Value;
                if (sid == null) continue;

                var numPr = style.StyleParagraphProperties?.NumberingProperties;
                if (numPr == null) continue;

                var nid = numPr.NumberingId?.Val?.Value ?? 0;
                var ilvl = numPr.NumberingLevelReference?.Val?.Value ?? 0;
                if (nid > 0)
                    map[sid] = (nid, ilvl);
            }

            return map;
        }

        private static void MarkHasChildren(List<DocumentHeading> headings)
        {
            for (int i = 0; i < headings.Count - 1; i++)
                headings[i].HasChildren = headings[i + 1].Level > headings[i].Level;
        }

        private static Dictionary<string, int> BuildLevelMap(StyleDefinitionsPart? stylesPart)
        {
            var map = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
            if (stylesPart?.Styles == null)
            {
                map["Heading1"] = 1; map["Heading2"] = 2; map["Heading3"] = 3;
                return map;
            }
            foreach (var style in stylesPart.Styles.Elements<Style>())
            {
                var id = style.StyleId?.Value;
                if (id == null) continue;
                var outlineLvl = style.StyleParagraphProperties?.OutlineLevel?.Val?.Value;
                if (outlineLvl.HasValue && outlineLvl.Value >= 0 && outlineLvl.Value <= 2)
                { map[id] = outlineLvl.Value + 1; continue; }
                var level = ParseHeadingNameLevel(style.StyleName?.Val?.Value ?? string.Empty);
                if (level.HasValue) map[id] = level.Value;
            }
            return map;
        }

        private static int? ParseHeadingNameLevel(string styleName)
        {
            var n = styleName.Replace(" ", "").ToLowerInvariant();
            foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
            {
                if (!n.StartsWith(prefix)) continue;
                var rest = n.Substring(prefix.Length);
                if (rest == "1") return 1;
                if (rest == "2") return 2;
                if (rest == "3") return 3;
            }
            return null;
        }
