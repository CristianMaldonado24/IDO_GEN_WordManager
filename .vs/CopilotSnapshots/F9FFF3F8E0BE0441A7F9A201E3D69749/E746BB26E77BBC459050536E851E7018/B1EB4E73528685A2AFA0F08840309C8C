using DocumentFormat.OpenXml.Packaging;
using DocumentFormat.OpenXml.Wordprocessing;
using IDO_GEN_WordManager.Models;
using System.Collections.Generic;
using System.IO;
using System.Linq;

namespace IDO_GEN_WordManager.Services
{
    public class WordExporterService
    {
        /// <summary>
        /// Exporta una copia del documento eliminando los párrafos de encabezado que tienen IsVisible=false.
        /// </summary>
        public void ExportFiltered(string sourcePath, string destPath, IEnumerable<DocumentHeading> headings)
        {
            File.Copy(sourcePath, destPath, overwrite: true);

            var hiddenIndexes = new HashSet<int>(
                headings.Where(h => !h.IsVisible).Select(h => h.ParagraphIndex));

            if (hiddenIndexes.Count == 0) return;

            using var doc = WordprocessingDocument.Open(destPath, true);
            var body = doc.MainDocumentPart?.Document?.Body;
            if (body == null) return;

            var paragraphs = body.Elements<Paragraph>().ToList();

            foreach (var idx in hiddenIndexes.OrderByDescending(i => i))
            {
                if (idx < paragraphs.Count)
                    paragraphs[idx].Remove();
            }

            doc.MainDocumentPart!.Document.Save();
        }
    }
}
