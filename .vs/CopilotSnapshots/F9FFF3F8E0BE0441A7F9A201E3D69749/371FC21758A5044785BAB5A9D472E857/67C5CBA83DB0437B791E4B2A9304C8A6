using IDO_GEN_WordManager.Models;
using System;
using System.Collections.Generic;
using System.IO;
using System.Runtime.InteropServices;

namespace IDO_GEN_WordManager.Services
{
    public class WordReaderService
    {
        public List<DocumentHeading> LoadHeadings(string filePath)
        {
            var result = new List<DocumentHeading>();
            if (!File.Exists(filePath))
            {
                return result;
            }

            object? wordApp = null;
            object? wordDoc = null;

            try
            {
                var wordType = Type.GetTypeFromProgID("Word.Application");
                if (wordType == null)
                {
                    throw new InvalidOperationException("Microsoft Word no está instalado o no registró el componente COM 'Word.Application'.");
                }

                wordApp = Activator.CreateInstance(wordType);
                if (wordApp == null)
                {
                    throw new InvalidOperationException("No se pudo iniciar Microsoft Word.");
                }

                SetProperty(wordApp, "Visible", false);
                SetProperty(wordApp, "DisplayAlerts", 0);

                var documents = GetProperty(wordApp, "Documents");
                wordDoc = InvokeMethod(documents!, "Open", Path.GetFullPath(filePath));

                var paragraphIndex = 0;
                var paragraphs = GetProperty(wordDoc!, "Paragraphs")!;
                var count = Convert.ToInt32(GetProperty(paragraphs, "Count"));

                for (var i = 1; i <= count; i++)
                {
                    var paragraph = GetIndexedItem(paragraphs, i);
                    try
                    {
                        var style = InvokeMethod(paragraph, "get_Style");
                        if (style == null)
                        {
                            paragraphIndex++;
                            continue;
                        }

                        var level = GetHeadingLevel(style);
                        if (level < 1 || level > 3)
                        {
                            paragraphIndex++;
                            continue;
                        }

                        var range = GetProperty(paragraph, "Range")!;
                        var rawText = GetProperty(range, "Text") as string;
                        var text = rawText?
                            .Replace("\r", string.Empty)
                            .Replace("\n", string.Empty)
                            .Replace("\a", string.Empty)
                            .Trim();
                        if (string.IsNullOrWhiteSpace(text))
                        {
                            paragraphIndex++;
                            continue;
                        }

                        string wordNumber;
                        try
                        {
                            var listFormat = GetProperty(range, "ListFormat")!;
                            wordNumber = GetProperty(listFormat, "ListString") as string ?? string.Empty;
                        }
                        catch
                        {
                            wordNumber = string.Empty;
                        }

                        result.Add(new DocumentHeading
                        {
                            ParagraphIndex = paragraphIndex,
                            Level = level,
                            Text = text,
                            WordNumber = wordNumber.Trim()
                        });
                    }
                    finally
                    {
                        ReleaseComObject(paragraph);
                        paragraphIndex++;
                    }
                }

                MarkHasChildren(result);
                return result;
            }
            finally
            {
                try
                {
                    if (wordDoc != null)
                    {
                        InvokeMethod(wordDoc, "Close", 0);
                    }
                }
                finally
                {
                    ReleaseComObject(wordDoc);
                }

                try
                {
                    if (wordApp != null)
                    {
                        InvokeMethod(wordApp, "Quit", 0);
                    }
                }
                finally
                {
                    ReleaseComObject(wordApp);
                }
            }
        }

        private static int GetHeadingLevel(object style)
        {
            try
            {
                var paragraphFormat = GetProperty(style, "ParagraphFormat")!;
                var outlineLevel = Convert.ToInt32(GetProperty(paragraphFormat, "OutlineLevel"));
                if (outlineLevel >= 1 && outlineLevel <= 3)
                {
                    return outlineLevel;
                }

                var styleName = ((GetProperty(style, "NameLocal") as string) ?? string.Empty)
                    .Replace(" ", string.Empty)
                    .ToLowerInvariant();

                foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
                {
                    if (!styleName.StartsWith(prefix))
                    {
                        continue;
                    }

                    var suffix = styleName.Substring(prefix.Length);
                    if (suffix == "1") return 1;
                    if (suffix == "2") return 2;
                    if (suffix == "3") return 3;
                }
            }
            catch
            {
            }

            return 0;
        }

        private static object? GetProperty(object target, string propertyName)
            => target.GetType().InvokeMember(propertyName, System.Reflection.BindingFlags.GetProperty, null, target, null);

        private static void SetProperty(object target, string propertyName, object? value)
            => target.GetType().InvokeMember(propertyName, System.Reflection.BindingFlags.SetProperty, null, target, new[] { value });

        private static object? InvokeMethod(object target, string methodName, params object?[] args)
            => target.GetType().InvokeMember(methodName, System.Reflection.BindingFlags.InvokeMethod, null, target, args);

        private static object GetIndexedItem(object collection, int index)
            => collection.GetType().InvokeMember("Item", System.Reflection.BindingFlags.GetProperty, null, collection, new object[] { index })!;

        private static void ReleaseComObject(object? value)
        {
            if (value != null && Marshal.IsComObject(value))
            {
                Marshal.ReleaseComObject(value);
            }
        }

        private static void MarkHasChildren(List<DocumentHeading> headings)
        {
            for (var i = 0; i < headings.Count - 1; i++)
            {
                headings[i].HasChildren = headings[i + 1].Level > headings[i].Level;
            }
        }
    }
}
