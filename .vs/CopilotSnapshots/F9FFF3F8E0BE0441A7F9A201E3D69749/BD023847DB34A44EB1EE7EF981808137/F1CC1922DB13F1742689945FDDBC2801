        /// <summary>
        /// Construye un mapa styleId -> nivel (1, 2, 3) leyendo los estilos del documento.
        /// Detecta headings por OutlineLevel o por nombre que contenga "heading" + número.
        /// </summary>
        private static Dictionary<string, int> BuildLevelMap(StyleDefinitionsPart? stylesPart)
        {
            var map = new Dictionary<string, int>(System.StringComparer.OrdinalIgnoreCase);

            if (stylesPart?.Styles == null)
            {
                // Sin estilos definidos: agregar IDs estándar de Word directamente
                map["Heading1"] = 1;
                map["Heading2"] = 2;
                map["Heading3"] = 3;
                return map;
            }

            foreach (var style in stylesPart.Styles.Elements<Style>())
            {
                var id = style.StyleId?.Value;
                if (id == null) continue;

                // 1. Detectar por OutlineLevel (0=Título, 1=Subtítulo, 2=Capítulo)
                var outlineLvl = style.StyleParagraphProperties?.OutlineLevel?.Val?.Value;
                if (outlineLvl.HasValue && outlineLvl.Value >= 0 && outlineLvl.Value <= 2)
                {
                    map[id] = outlineLvl.Value + 1;
                    continue;
                }

                // 2. Detectar por nombre de estilo que siga el patrón "heading N"
                var name = style.StyleName?.Val?.Value ?? string.Empty;
                var level = ParseHeadingNameLevel(name);
                if (level.HasValue)
                    map[id] = level.Value;
            }

            return map;
        }

        private static int? ParseHeadingNameLevel(string styleName)
        {
            // Coincide con: "Heading 1", "heading1", "Título 1", "título1", etc.
            var normalized = styleName.Replace(" ", "").ToLowerInvariant();
            foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
            {
                if (normalized.StartsWith(prefix))
                {
                    var rest = normalized.Substring(prefix.Length);
                    if (rest == "1" || rest == "one") return 1;
                    if (rest == "2" || rest == "two") return 2;
                    if (rest == "3" || rest == "three") return 3;
                }
            }
            return null;
        }
    }
