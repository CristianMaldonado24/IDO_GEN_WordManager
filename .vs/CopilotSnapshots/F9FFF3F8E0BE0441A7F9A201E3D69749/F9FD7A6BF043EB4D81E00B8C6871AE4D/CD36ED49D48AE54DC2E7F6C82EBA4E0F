using DocumentFormat.OpenXml.Packaging;
using DocumentFormat.OpenXml.Wordprocessing;
using IDO_GEN_WordManager.Models;
using System;
using System.Collections.Generic;
using System.IO;
using System.Linq;
using System.Text.RegularExpressions;

namespace IDO_GEN_WordManager.Services
{
    public class WordReaderService
    {
        public List<DocumentHeading> LoadHeadings(string filePath)
        {
            var result = new List<DocumentHeading>();
            if (!File.Exists(filePath)) return result;

            using var doc = WordprocessingDocument.Open(filePath, false);
            var body = doc.MainDocumentPart?.Document?.Body;
            if (body == null) return result;

            var levelMap = BuildLevelMap(doc.MainDocumentPart?.StyleDefinitionsPart);
            var numPart = doc.MainDocumentPart?.NumberingDefinitionsPart;
            var stylePart = doc.MainDocumentPart?.StyleDefinitionsPart;

            // Resolver numId implícito por estilo (cuando el estilo tiene numId definido)
            var styleNumIds = ResolveStyleNumbering(stylePart, numPart);

            // Pasada 1: recorrer TODOS los párrafos y acumular contadores de numeración
            // Así reproducimos exactamente lo que Word computa internamente
            var allParagraphs = body.Elements<Paragraph>().ToList();
            var paraNumbers = ComputeAllNumbers(allParagraphs, numPart, styleNumIds);

            // Pasada 2: filtrar solo los headings
            for (int index = 0; index < allParagraphs.Count; index++)
            {
                var para = allParagraphs[index];
                var styleId = para.ParagraphProperties?.ParagraphStyleId?.Val?.Value;
                if (styleId == null || !levelMap.TryGetValue(styleId, out int level)) continue;

                var text = para.InnerText?.Trim();
                if (string.IsNullOrWhiteSpace(text)) continue;

                var number = paraNumbers.TryGetValue(index, out string? n) ? n : string.Empty;
                result.Add(new DocumentHeading
                {
                    ParagraphIndex = index,
                    Level = level,
                    Text = text,
                    WordNumber = number
                });
            }

            MarkHasChildren(result);
            return result;
        }

        /// <summary>
        /// Recorre TODOS los párrafos (no solo headings) y computa el número de numeración
        /// visible para cada párrafo que participa en una lista.
        /// </summary>
        private static Dictionary<int, string> ComputeAllNumbers(
            List<Paragraph> paragraphs,
            NumberingDefinitionsPart? numPart,
            Dictionary<string, (int numId, int ilvl)> styleNumIds)
        {
            var result = new Dictionary<int, string>();

            if (numPart?.Numbering == null)
            {
                // Sin numbering part: generar números jerárquicos por nivel de heading
                return result;
            }

            // numId -> abstractNumId
            var numToAbstract = new Dictionary<int, int>();
            // numId -> startOverrides (ilvl -> start) — solo los que aún no se aplicaron
            var startOverrides = new Dictionary<int, Dictionary<int, int>>();
            // abstractNumId -> formato de número por nivel (para saber cuántos niveles mostrar)
            var abstractFormats = new Dictionary<int, Dictionary<int, string>>();

            foreach (var num in numPart.Numbering.Elements<NumberingInstance>())
            {
                var nid = num.NumberID?.Value ?? 0;
                var aid = num.AbstractNumId?.Val?.Value ?? 0;
                numToAbstract[nid] = aid;

                var ov = new Dictionary<int, int>();
                foreach (var lo in num.Elements<LevelOverride>())
                {
                    var lvl = lo.LevelIndex?.Value ?? 0;
                    var sv = lo.StartOverrideNumberingValue?.Val?.Value;
                    if (sv.HasValue) ov[lvl] = sv.Value;
                }
                if (ov.Count > 0) startOverrides[nid] = ov;
            }

            foreach (var abs in numPart.Numbering.Elements<AbstractNum>())
            {
                var aid = abs.AbstractNumberId?.Value ?? 0;
                var formats = new Dictionary<int, string>();
                foreach (var lvl in abs.Elements<Level>())
                {
                    var ilvl = lvl.LevelIndex?.Value ?? 0;
                    var fmt = lvl.LevelText?.Val?.Value ?? string.Empty;
                    formats[ilvl] = fmt;
                }
                abstractFormats[aid] = formats;
            }

            // Contadores: abstractNumId -> int[9] (contadores por nivel)
            var counters = new Dictionary<int, int[]>();
            foreach (var aid in numToAbstract.Values.Distinct())
                counters[aid] = new int[9];

            for (int idx = 0; idx < paragraphs.Count; idx++)
            {
                var para = paragraphs[idx];
                var ppr = para.ParagraphProperties;
                var numPr = ppr?.NumberingProperties;

                int numId = numPr?.NumberingId?.Val?.Value ?? 0;
                int ilvl = numPr?.NumberingLevelReference?.Val?.Value ?? -1;

                // Si no tiene numPr directo, intentar por estilo
                if (numId == 0)
                {
                    var sid = ppr?.ParagraphStyleId?.Val?.Value;
                    if (sid != null && styleNumIds.TryGetValue(sid, out var sn))
                    {
                        numId = sn.numId;
                        if (ilvl < 0) ilvl = sn.ilvl;
                    }
                }

                if (numId == 0 || !numToAbstract.TryGetValue(numId, out int absId))
                    continue;

                if (ilvl < 0) ilvl = 0;
                if (!counters.TryGetValue(absId, out var ctr))
                {
                    ctr = new int[9];
                    counters[absId] = ctr;
                }

                // Aplicar startOverride
                if (startOverrides.TryGetValue(numId, out var ovMap) && ovMap.TryGetValue(ilvl, out int startVal))
                {
                    ctr[ilvl] = startVal - 1;
                    ovMap.Remove(ilvl);
                }

                // Incrementar nivel actual
                ctr[ilvl]++;

                // Resetear niveles inferiores
                for (int i = ilvl + 1; i < ctr.Length; i++)
                    ctr[i] = 0;

                // Formatear el número usando el LevelText del abstractNum
                string formatted;
                if (abstractFormats.TryGetValue(absId, out var fmts) && fmts.TryGetValue(ilvl, out string? lvlText))
                {
                    formatted = FormatLevelText(lvlText, ctr);
                }
                else
                {
                    // Fallback: mostrar solo el contador del nivel actual
                    var parts = new List<string>();
                    for (int i = 0; i <= ilvl; i++)
                        if (ctr[i] > 0) parts.Add(ctr[i].ToString());
                    formatted = string.Join(".", parts);
                }

                result[idx] = formatted;
            }

            return result;
        }

        /// <summary>
        /// Formatea el LevelText de Word. Ej: "%1.%2.%3" reemplaza %N con el contador del nivel N-1.
        /// </summary>
        private static string FormatLevelText(string levelText, int[] counters)
        {
            // Word usa %1, %2, %3 como placeholders para nivel 0, 1, 2 respectivamente
            var formatted = Regex.Replace(levelText, @"%(\d)", m =>
            {
                int lvl = int.Parse(m.Groups[1].Value) - 1; // %1 = nivel 0
                return lvl >= 0 && lvl < counters.Length ? counters[lvl].ToString() : "0";
            });

            // Limpiar trailing dots/chars si algún nivel es 0
            formatted = formatted.TrimEnd('.');
            return formatted;
        }

        /// <summary>
        /// Lee los numId implícitos definidos en los estilos (ej: Heading1 suele tener un numId asociado).
        /// </summary>
        private static Dictionary<string, (int numId, int ilvl)> ResolveStyleNumbering(
            StyleDefinitionsPart? stylePart, NumberingDefinitionsPart? numPart)
        {
            var map = new Dictionary<string, (int, int)>(StringComparer.OrdinalIgnoreCase);
            if (stylePart?.Styles == null) return map;

            foreach (var style in stylePart.Styles.Elements<Style>())
            {
                var sid = style.StyleId?.Value;
                if (sid == null) continue;

                var numPr = style.StyleParagraphProperties?.NumberingProperties;
                if (numPr == null) continue;

                var nid = numPr.NumberingId?.Val?.Value ?? 0;
                var ilvl = numPr.NumberingLevelReference?.Val?.Value ?? 0;
                if (nid > 0)
                    map[sid] = (nid, ilvl);
            }

            return map;
        }

        private static void MarkHasChildren(List<DocumentHeading> headings)
        {
            for (int i = 0; i < headings.Count - 1; i++)
                headings[i].HasChildren = headings[i + 1].Level > headings[i].Level;
        }

        private static Dictionary<string, int> BuildLevelMap(StyleDefinitionsPart? stylesPart)
        {
            var map = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
            if (stylesPart?.Styles == null)
            {
                map["Heading1"] = 1; map["Heading2"] = 2; map["Heading3"] = 3;
                return map;
            }
            foreach (var style in stylesPart.Styles.Elements<Style>())
            {
                var id = style.StyleId?.Value;
                if (id == null) continue;
                var outlineLvl = style.StyleParagraphProperties?.OutlineLevel?.Val?.Value;
                if (outlineLvl.HasValue && outlineLvl.Value >= 0 && outlineLvl.Value <= 2)
                { map[id] = outlineLvl.Value + 1; continue; }
                var level = ParseHeadingNameLevel(style.StyleName?.Val?.Value ?? string.Empty);
                if (level.HasValue) map[id] = level.Value;
            }
            return map;
        }

        private static int? ParseHeadingNameLevel(string styleName)
        {
            var n = styleName.Replace(" ", "").ToLowerInvariant();
            foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
            {
                if (!n.StartsWith(prefix)) continue;
                var rest = n.Substring(prefix.Length);
                if (rest == "1") return 1;
                if (rest == "2") return 2;
                if (rest == "3") return 3;
            }
            return null;
        }
    }
}

        public List<DocumentHeading> LoadHeadings(string filePath)
        {
            var result = new List<DocumentHeading>();
            if (!File.Exists(filePath)) return result;

            using var doc = WordprocessingDocument.Open(filePath, false);
            var body = doc.MainDocumentPart?.Document?.Body;
            if (body == null) return result;

            var levelMap    = BuildLevelMap(doc.MainDocumentPart?.StyleDefinitionsPart);
            var numCounters = new NumberingCounters(doc.MainDocumentPart?.NumberingDefinitionsPart);

            int index = 0;
            foreach (var para in body.Elements<Paragraph>())
            {
                var styleId = para.ParagraphProperties?.ParagraphStyleId?.Val?.Value;
                if (styleId != null && levelMap.TryGetValue(styleId, out int level))
                {
                    var text = para.InnerText?.Trim();
                    if (!string.IsNullOrWhiteSpace(text))
                    {
                        var wordNumber = numCounters.GetNumber(para, level);
                        result.Add(new DocumentHeading { ParagraphIndex = index, Level = level, Text = text, WordNumber = wordNumber });
                    }
                }
                index++;
            }

            MarkHasChildren(result);
            return result;
        }

        private static void MarkHasChildren(List<DocumentHeading> headings)
        {
            for (int i = 0; i < headings.Count - 1; i++)
                headings[i].HasChildren = headings[i + 1].Level > headings[i].Level;
        }

        private static Dictionary<string, int> BuildLevelMap(StyleDefinitionsPart? stylesPart)
        {
            var map = new Dictionary<string, int>(System.StringComparer.OrdinalIgnoreCase);
            if (stylesPart?.Styles == null)
            {
                map["Heading1"] = 1; map["Heading2"] = 2; map["Heading3"] = 3;
                return map;
            }
            foreach (var style in stylesPart.Styles.Elements<Style>())
            {
                var id = style.StyleId?.Value;
                if (id == null) continue;
                var outlineLvl = style.StyleParagraphProperties?.OutlineLevel?.Val?.Value;
                if (outlineLvl.HasValue && outlineLvl.Value >= 0 && outlineLvl.Value <= 2)
                { map[id] = outlineLvl.Value + 1; continue; }
                var level = ParseHeadingNameLevel(style.StyleName?.Val?.Value ?? string.Empty);
                if (level.HasValue) map[id] = level.Value;
            }
            return map;
        }

        private static int? ParseHeadingNameLevel(string styleName)
        {
            var n = styleName.Replace(" ", "").ToLowerInvariant();
            foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
            {
                if (!n.StartsWith(prefix)) continue;
                var rest = n.Substring(prefix.Length);
                if (rest == "1") return 1;
                if (rest == "2") return 2;
                if (rest == "3") return 3;
            }
            return null;
        }
    }

    /// <summary>
    /// Rastrea los contadores de numeración del documento Word para reproducir
    /// exactamente el número visible (ej: "1", "1.2", "1.2.3") igual que en Word/Excel.
    /// </summary>
    internal class NumberingCounters
    {
        // abstractNumId -> (ilvl -> contador actual)
        private readonly Dictionary<int, int[]> _counters = new();
        // numId -> abstractNumId
        private readonly Dictionary<int, int> _numToAbstract = new();
        // numId -> startOverride por nivel
        private readonly Dictionary<int, Dictionary<int, int>> _startOverrides = new();
        private readonly bool _hasNumbering;

        public NumberingCounters(NumberingDefinitionsPart? numPart)
        {
            if (numPart?.Numbering == null) { _hasNumbering = false; return; }
            _hasNumbering = true;

            // Mapear numId -> abstractNumId y leer startOverrides
            foreach (var num in numPart.Numbering.Elements<NumberingInstance>())
            {
                var numId = num.NumberID?.Value ?? 0;
                var absId = num.AbstractNumId?.Val?.Value ?? 0;
                _numToAbstract[numId] = absId;

                var overrides = new Dictionary<int, int>();
                foreach (var lvlOverride in num.Elements<LevelOverride>())
                {
                    var ilvl = lvlOverride.LevelIndex?.Value ?? 0;
                    var startOvr = lvlOverride.StartOverrideNumberingValue?.Val?.Value;
                    if (startOvr.HasValue)
                        overrides[ilvl] = startOvr.Value;
                }
                if (overrides.Count > 0)
                    _startOverrides[numId] = overrides;
            }

            // Inicializar contadores (máximo 9 niveles por abstractNum)
            foreach (var absId in _numToAbstract.Values.Distinct())
                _counters[absId] = new int[9];
        }

        /// <summary>
        /// Calcula el número jerárquico del párrafo usando los contadores de numeración de Word.
        /// Si el documento no tiene numeración, genera números secuenciales por nivel.
        /// </summary>
        public string GetNumber(Paragraph para, int headingLevel)
        {
            if (!_hasNumbering)
                return FallbackNumber(headingLevel);

            var numPr = para.ParagraphProperties?.NumberingProperties;
            var numId = numPr?.NumberingId?.Val?.Value ?? 0;
            var ilvl  = numPr?.NumberingLevelReference?.Val?.Value ?? (headingLevel - 1);

            if (numId == 0 || !_numToAbstract.TryGetValue(numId, out int absId))
                return FallbackNumber(headingLevel);

            var counters = _counters[absId];

            // Aplicar startOverride si existe para este nivel
            if (_startOverrides.TryGetValue(numId, out var overrides) && overrides.TryGetValue(ilvl, out int startVal))
            {
                counters[ilvl] = startVal - 1; // se incrementará en la siguiente línea
                overrides.Remove(ilvl);         // aplicar solo una vez
            }

            // Incrementar nivel actual y resetear niveles inferiores
            counters[ilvl]++;
            for (int i = ilvl + 1; i < counters.Length; i++)
                counters[i] = 0;

            // Construir número jerárquico con los niveles activos hasta ilvl
            var parts = new List<string>();
            for (int i = 0; i <= ilvl; i++)
                if (counters[i] > 0) parts.Add(counters[i].ToString());

            return string.Join(".", parts);
        }

        // Contadores de fallback cuando no hay numeración en el documento
        private readonly int[] _fallback = new int[9];
        private string FallbackNumber(int headingLevel)
        {
            int ilvl = headingLevel - 1;
            _fallback[ilvl]++;
            for (int i = ilvl + 1; i < _fallback.Length; i++)
                _fallback[i] = 0;

            var parts = new List<string>();
            for (int i = 0; i <= ilvl; i++)
                if (_fallback[i] > 0) parts.Add(_fallback[i].ToString());
            return string.Join(".", parts);
        }
    }
}
