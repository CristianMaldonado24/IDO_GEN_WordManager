using DocumentFormat.OpenXml.Packaging;
using DocumentFormat.OpenXml.Wordprocessing;
using IDO_GEN_WordManager.Models;
using System.Collections.Generic;
using System.IO;
using System.Linq;

namespace IDO_GEN_WordManager.Services
{
    public class WordReaderService
    {
        public List<DocumentHeading> LoadHeadings(string filePath)
        {
            var result = new List<DocumentHeading>();
            if (!File.Exists(filePath)) return result;

            using var doc = WordprocessingDocument.Open(filePath, false);
            var body = doc.MainDocumentPart?.Document?.Body;
            if (body == null) return result;

            var levelMap    = BuildLevelMap(doc.MainDocumentPart?.StyleDefinitionsPart);
            var numCounters = new NumberingCounters(doc.MainDocumentPart?.NumberingDefinitionsPart);

            int index = 0;
            foreach (var para in body.Elements<Paragraph>())
            {
                var styleId = para.ParagraphProperties?.ParagraphStyleId?.Val?.Value;
                if (styleId != null && levelMap.TryGetValue(styleId, out int level))
                {
                    var text = para.InnerText?.Trim();
                    if (!string.IsNullOrWhiteSpace(text))
                    {
                        var wordNumber = numCounters.GetNumber(para, level);
                        result.Add(new DocumentHeading { ParagraphIndex = index, Level = level, Text = text, WordNumber = wordNumber });
                    }
                }
                index++;
            }

            MarkHasChildren(result);
            return result;
        }

        private static void MarkHasChildren(List<DocumentHeading> headings)
        {
            for (int i = 0; i < headings.Count - 1; i++)
                headings[i].HasChildren = headings[i + 1].Level > headings[i].Level;
        }

        private static Dictionary<string, int> BuildLevelMap(StyleDefinitionsPart? stylesPart)
        {
            var map = new Dictionary<string, int>(System.StringComparer.OrdinalIgnoreCase);
            if (stylesPart?.Styles == null)
            {
                map["Heading1"] = 1; map["Heading2"] = 2; map["Heading3"] = 3;
                return map;
            }
            foreach (var style in stylesPart.Styles.Elements<Style>())
            {
                var id = style.StyleId?.Value;
                if (id == null) continue;
                var outlineLvl = style.StyleParagraphProperties?.OutlineLevel?.Val?.Value;
                if (outlineLvl.HasValue && outlineLvl.Value >= 0 && outlineLvl.Value <= 2)
                { map[id] = outlineLvl.Value + 1; continue; }
                var level = ParseHeadingNameLevel(style.StyleName?.Val?.Value ?? string.Empty);
                if (level.HasValue) map[id] = level.Value;
            }
            return map;
        }

        private static int? ParseHeadingNameLevel(string styleName)
        {
            var n = styleName.Replace(" ", "").ToLowerInvariant();
            foreach (var prefix in new[] { "heading", "título", "titulo", "encabezado" })
            {
                if (!n.StartsWith(prefix)) continue;
                var rest = n.Substring(prefix.Length);
                if (rest == "1") return 1;
                if (rest == "2") return 2;
                if (rest == "3") return 3;
            }
            return null;
        }
    }

    /// <summary>
    /// Rastrea los contadores de numeración del documento Word para reproducir
    /// exactamente el número visible (ej: "1", "1.2", "1.2.3") igual que en Word/Excel.
    /// </summary>
    internal class NumberingCounters
    {
        // abstractNumId -> (ilvl -> contador actual)
        private readonly Dictionary<int, int[]> _counters = new();
        // numId -> abstractNumId
        private readonly Dictionary<int, int> _numToAbstract = new();
        // numId -> startOverride por nivel
        private readonly Dictionary<int, Dictionary<int, int>> _startOverrides = new();
        private readonly bool _hasNumbering;

        public NumberingCounters(NumberingDefinitionsPart? numPart)
        {
            if (numPart?.Numbering == null) { _hasNumbering = false; return; }
            _hasNumbering = true;

            // Mapear numId -> abstractNumId y leer startOverrides
            foreach (var num in numPart.Numbering.Elements<NumberingInstance>())
            {
                var numId = num.NumberID?.Value ?? 0;
                var absId = num.AbstractNumId?.Val?.Value ?? 0;
                _numToAbstract[numId] = absId;

                var overrides = new Dictionary<int, int>();
                foreach (var lvlOverride in num.Elements<LevelOverride>())
                {
                    var ilvl = lvlOverride.LevelIndex?.Value ?? 0;
                    var startOvr = lvlOverride.StartOverrideNumberingValue?.Val?.Value;
                    if (startOvr.HasValue)
                        overrides[ilvl] = startOvr.Value;
                }
                if (overrides.Count > 0)
                    _startOverrides[numId] = overrides;
            }

            // Inicializar contadores (máximo 9 niveles por abstractNum)
            foreach (var absId in _numToAbstract.Values.Distinct())
                _counters[absId] = new int[9];
        }

        /// <summary>
        /// Calcula el número jerárquico del párrafo usando los contadores de numeración de Word.
        /// Si el documento no tiene numeración, genera números secuenciales por nivel.
        /// </summary>
        public string GetNumber(Paragraph para, int headingLevel)
        {
            if (!_hasNumbering)
                return FallbackNumber(headingLevel);

            var numPr = para.ParagraphProperties?.NumberingProperties;
            var numId = numPr?.NumberingId?.Val?.Value ?? 0;
            var ilvl  = numPr?.NumberingLevelReference?.Val?.Value ?? (headingLevel - 1);

            if (numId == 0 || !_numToAbstract.TryGetValue(numId, out int absId))
                return FallbackNumber(headingLevel);

            var counters = _counters[absId];

            // Aplicar startOverride si existe para este nivel
            if (_startOverrides.TryGetValue(numId, out var overrides) && overrides.TryGetValue(ilvl, out int startVal))
            {
                counters[ilvl] = startVal - 1; // se incrementará en la siguiente línea
                overrides.Remove(ilvl);         // aplicar solo una vez
            }

            // Incrementar nivel actual y resetear niveles inferiores
            counters[ilvl]++;
            for (int i = ilvl + 1; i < counters.Length; i++)
                counters[i] = 0;

            // Construir número jerárquico con los niveles activos hasta ilvl
            var parts = new List<string>();
            for (int i = 0; i <= ilvl; i++)
                if (counters[i] > 0) parts.Add(counters[i].ToString());

            return string.Join(".", parts);
        }

        // Contadores de fallback cuando no hay numeración en el documento
        private readonly int[] _fallback = new int[9];
        private string FallbackNumber(int headingLevel)
        {
            int ilvl = headingLevel - 1;
            _fallback[ilvl]++;
            for (int i = ilvl + 1; i < _fallback.Length; i++)
                _fallback[i] = 0;

            var parts = new List<string>();
            for (int i = 0; i <= ilvl; i++)
                if (_fallback[i] > 0) parts.Add(_fallback[i].ToString());
            return string.Join(".", parts);
        }
    }
}
